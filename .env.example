# Token atual (atualizado automaticamente pelo silent renewal)
TICKET_ACCESS_TOKEN=
TICKET_TOKEN_EXPIRES_AT=

# Cookie SSO do Azure B2C — renovado automaticamente via reauth
B2C_SSO_COOKIE=

# Credenciais para reauth automático (Puppeteer + Gmail IMAP)
TICKET_EMAIL=
TICKET_PASSWORD=
GMAIL_APP_PASSWORD=   # senha de app do Google (não a senha normal)

# ID do cartão ativo
TICKET_CARD_ID=
X_USER_ID=

# Azure B2C
B2C_TENANT=
B2C_POLICY=
B2C_CLIENT_ID=

PORT=3000

# Evolution API
EVOLUTION_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WEBHOOK_URL=
INSTANCE_PHONE=
